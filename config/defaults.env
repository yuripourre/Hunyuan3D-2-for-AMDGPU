# Hunyuan3D-2 ROCm setup defaults (override via environment variables)

PYTHON_MIN=3.10

TORCH_VERSION=2.7.1
TORCHVISION_VERSION=0.22.1
TORCHAUDIO_VERSION=2.7.1
PYTORCH_ROCM_INDEX=https://download.pytorch.org/whl/rocm6.3

GPU_ARCHS=auto
FLASH_ATTENTION_TRITON_AMD_ENABLE=TRUE
FLASH_ATTENTION_REPO=https://github.com/ROCm/flash-attention.git
FLASH_ATTENTION_BRANCH=main_perf

HUNYUAN3D_REPO=https://github.com/Tencent-Hunyuan/Hunyuan3D-2.git
HUNYUAN3D_DIR=vendor/Hunyuan3D-2

GRADIO_PORT=8080
